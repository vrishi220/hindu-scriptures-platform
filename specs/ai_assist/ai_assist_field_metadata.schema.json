{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hindu-scriptures-platform/specs/ai_assist/ai_assist_field_metadata.schema.json",
  "title": "AI Assist Field Metadata",
  "description": "Schema for field-level AI assist configuration in scripture authoring metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": ["enabled", "target_kind", "apply_policy", "permission"],
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Whether AI assist is available for this field."
    },
    "target_kind": {
      "type": "string",
      "enum": ["generate", "transform", "suggest"],
      "description": "Primary assist mode for this field."
    },
    "allow_user_prompt_edit": {
      "type": "boolean",
      "default": true,
      "description": "Whether user can edit the default prompt before generation."
    },
    "apply_policy": {
      "type": "string",
      "enum": ["manual_only"],
      "description": "How AI output may be applied to field values."
    },
    "context_sources": {
      "type": "array",
      "description": "Context keys available for prompt templating.",
      "items": {
        "$ref": "#/$defs/contextSource"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "prompt_template_id": {
      "type": "string",
      "description": "Template identifier from the prompt library."
    },
    "default_prompt_template": {
      "type": "string",
      "description": "Inline fallback template used when prompt_template_id is not provided.",
      "minLength": 10
    },
    "prompt_variables": {
      "type": "array",
      "description": "Optional variable declarations for UI clarity and validation.",
      "items": {
        "$ref": "#/$defs/promptVariable"
      },
      "uniqueItems": true
    },
    "output": {
      "$ref": "#/$defs/outputConfig"
    },
    "validation": {
      "$ref": "#/$defs/validationConfig"
    },
    "permission": {
      "$ref": "#/$defs/permissionConfig"
    },
    "provenance": {
      "$ref": "#/$defs/provenanceConfig"
    },
    "rate_limit": {
      "$ref": "#/$defs/rateLimitConfig"
    },
    "ui": {
      "$ref": "#/$defs/uiConfig"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "enabled": { "const": true } },
        "required": ["enabled"]
      },
      "then": {
        "anyOf": [
          { "required": ["prompt_template_id"] },
          { "required": ["default_prompt_template"] }
        ],
        "required": ["context_sources", "output"]
      }
    }
  ],
  "$defs": {
    "contextSource": {
      "type": "string",
      "enum": [
        "book_id",
        "book_name",
        "book_code",
        "node_id",
        "node_path",
        "level_name",
        "sequence_number",
        "field_name",
        "field_label",
        "source_language",
        "preferred_script",
        "previous_node_text",
        "next_node_text",
        "selected_text",
        "user_instruction"
      ]
    },
    "promptVariable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "required"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "default": {
          "type": ["string", "number", "boolean", "null"]
        }
      }
    },
    "outputConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["plain", "devanagari", "iast", "iso15919", "json"]
        },
        "schema_ref": {
          "type": "string",
          "description": "Required when format=json; references expected output schema."
        },
        "max_chars": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20000
        },
        "trim_whitespace": {
          "type": "boolean",
          "default": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "format": { "const": "json" } },
            "required": ["format"]
          },
          "then": {
            "required": ["schema_ref"]
          }
        }
      ]
    },
    "validationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "script_check": {
          "type": "string",
          "enum": ["none", "devanagari", "iast", "iso15919", "latin"]
        },
        "forbid_html": {
          "type": "boolean",
          "default": true
        },
        "forbid_markdown": {
          "type": "boolean",
          "default": true
        },
        "min_chars": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20000
        },
        "max_chars": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20000
        },
        "regex_allow": {
          "type": "string"
        },
        "regex_deny": {
          "type": "string"
        }
      }
    },
    "permissionConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles_allowed", "scope"],
      "properties": {
        "roles_allowed": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["admin", "editor", "contributor"]
          }
        },
        "scope": {
          "type": "string",
          "enum": ["book", "node", "draft_book"]
        },
        "require_edit_permission": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "provenanceConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "store_prompt": { "type": "boolean", "default": true },
        "store_response": { "type": "boolean", "default": true },
        "store_model": { "type": "boolean", "default": true },
        "store_context_snapshot": { "type": "boolean", "default": true },
        "require_user_ack": { "type": "boolean", "default": false }
      }
    },
    "rateLimitConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests_per_minute": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "requests_per_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5000
        }
      }
    },
    "uiConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "button_label": {
          "type": "string",
          "default": "AI Help"
        },
        "dialog_title": {
          "type": "string"
        },
        "show_context_chips": {
          "type": "boolean",
          "default": true
        },
        "allow_regenerate": {
          "type": "boolean",
          "default": true
        },
        "allow_refine": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
