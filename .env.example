# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/hindu_scriptures
LOCAL_DATABASE_URL=postgresql://username:password@localhost:5432/hindu_scriptures
RAILWAY_DATABASE_URL=postgresql://username:password@host:port/railway

# Secret Key for Session Management (generate a strong random string)
SECRET_KEY=your-secret-key-here

# OpenAI API Key for embeddings/AI features
OPENAI_API_KEY=your-openai-api-key-here

# Media Storage Configuration
# local/filesystem/railway-volume all use MEDIA_DIR on disk
MEDIA_STORAGE_BACKEND=local
# Set to mounted persistent path in Railway (example: /data/media)
MEDIA_DIR=media
MEDIA_URL_PREFIX=/media
MAX_UPLOAD_MB=50

# About Page
NEXT_PUBLIC_COMPANY_NAME=Hindu Scriptures Platform
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_CONTACT_PHONE=+1-555-555-5555
NEXT_PUBLIC_CONTACT_ADDRESS=123 Example St, City, Country
NEXT_PUBLIC_APP_VERSION=0.1
NEXT_PUBLIC_BUILD_NUMBER=0
NEXT_PUBLIC_GIT_SHA=local
